# Environment Variables Template
# Copy this file to .env and fill in your values
# Last updated: Phase A (A2.7) — Added all required variables

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/smart_clinic
DB_SSL_MODE=require

# ============================================
# SECURITY KEYS (CRITICAL — Generate new ones!)
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your_secret_key_here_min_64_chars_never_reuse

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# ============================================
# APPLICATION
# ============================================
ENVIRONMENT=production
BACKEND_PUBLIC_URL=https://your-backend-url.com
FRONTEND_URL=https://your-frontend-url.com

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ============================================
# AI SERVICES
# ============================================
# Get from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# FILE STORAGE (Optional — Cloudinary)
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================
# GOOGLE OAUTH (Optional — Google Drive Backup)
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-backend-url.com/api/v1/settings/backup/callback

# ============================================
# MONITORING & ALERTS (Optional)
# ============================================
# REDIS_URL=redis://localhost:6379
# SENTRY_DSN=your_sentry_dsn
# SLACK_WEBHOOK_URL=your_slack_webhook
